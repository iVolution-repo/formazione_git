{
  "compilerOptions": {
    "checkJs": true,
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitThis": true,
    "useUnknownInCatchVariables": false 
  },
  "include": ["**/*.js", "globals.d.ts"],
  "exclude": ["node_modules"]
}