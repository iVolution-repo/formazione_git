# ---------------------------------------------------------------------------
# Configurazione dell'applicazione.
# Copia questo file in ".env" e valorizza i campi con i dati reali.
# Il file .env NON va versionato su Git (aggiungilo a .gitignore).
# ---------------------------------------------------------------------------

# Porta su cui l'applicazione Express resta in ascolto
PORT=3000

# --- Parametri di connessione a DB2 for i ---------------------------------
# HOSTNAME: indirizzo/nome host del sistema IBM i
DB2_HOST=il-tuo-host-ibmi

# PORT: porta DRDA usata dal driver CLI (446 = default; 448 per TLS)
DB2_PORT=446

# DATABASE: nome RDB del sistema (lo trovi con WRKRDBDIRE su IBM i)
DB2_DATABASE=NOME_RDB

# Credenziali del profilo utente IBM i
DB2_UID=utente
DB2_PWD=password
